{
  "title": "REST & Kafka Services",
  "panels": [
    {
      "title": "HTTP Latency p50/p95/p99",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le, uri, method) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "p99 {{method}} {{uri}}" },
        { "expr": "histogram_quantile(0.95, sum by (le, uri, method) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "p95 {{method}} {{uri}}" }
      ]
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "stat",
      "targets": [
        { "expr": "sum by (group, topic) (kafka_consumer_fetch_manager_records_lag)", "legendFormat": "{{group}}" }
      ]
    },
    {
      "title": "Application Logs (WARN/ERROR)",
      "type": "logs",
      "datasource": {"type": "loki", "uid": "loki-thomas-vitale"},
      "targets": [
        { "expr": "{application=\"$application\"} | json | level=~\"(?i)WARN|ERROR\"" }
      ]
    }
  ]
}